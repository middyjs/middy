#!/usr/bin/env sh
# ./bin/certificates
# Ref: https://docs.aws.amazon.com/AmazonRDS/latest/UserGuide/UsingWithRDS.SSL.html#UsingWithRDS.SSL.CertificatesAllRegions

rm -rf certificates
mkdir -p certificates
cd certificates

updateExport () {
	key="./certificates/${1}"
	value="./certificates/${1}.js"
	jq --indent 1 --tab --arg k "$key" --arg v "$value" '.exports[$k] = {"import": { "default": $v } }' ../package.json > ../_package.json
	mv ../_package.json ../package.json
}

download () {
  curl -s https://truststore.pki.rds.amazonaws.com/${1}/${1}-bundle.pem -o ${1}-bundle.pem
}
regions=(
	"global"
	"us-east-1"      # US East (N. Virginia)
	"us-east-2"      # US East (Ohio)
	"us-west-1"      # US West (N. California)
	"us-west-2"      # US West (Oregon)
	"af-south-1"     # Africa (Cape Town)
	"ap-east-1"      # Asia Pacific (Hong Kong)
	"ap-south-2"     # Asia Pacific (Hyderabad)
	"ap-southeast-3" # Asia Pacific (Jakarta)
	"ap-southeast-4" # Asia Pacific (Melbourne)
	"ap-southeast-5" # Asia Pacific (Malaysia)
	"ap-southeast-7" # Asia Pacific (Thailand)
	"ap-south-1"     # Asia Pacific (Mumbai)
	"ap-northeast-3" # Asia Pacific (Osaka)
	"ap-northeast-1" # Asia Pacific (Tokyo)
	"ap-northeast-2" # Asia Pacific (Seoul)
	"ap-southeast-1" # Asia Pacific (Singapore)
	"ap-southeast-2" # Asia Pacific (Sydney)
	"ca-central-1"   # Canada East (Montreal)
	"ca-west-1"      # Canada West (Calgary)
	"eu-central-1"   # Europe (Frankfurt)
	"eu-west-1"      # Europe (Ireland)
	"eu-west-2"      # Europe (London)
	"eu-south-1"     # Europe (Milan)
	"eu-west-3"      # Europe (Paris)
	"eu-south-2"     # Europe (Spain)
	"eu-north-1"     # Europe (Stockholm)
	"eu-central-2"   # Europe (Zurich)
	"il-central-1"   # Israel (Tel Aviv)
	"me-south-1"     # Middle East (Bahrain)
	"me-central-1"   # Middle East (UAE)
	"mx-central-1"   # Mexico (Central)
	"sa-east-1"      # South America (São Paulo)
)
for region in "${regions[@]}"; do
   download ${region}
   echo "export default \`$(cat ${region}-bundle.pem)\`" > ${region}.js
   updateExport ${region}
done

downloadGov () {
  curl -s https://truststore.pki.us-gov-west-1.rds.amazonaws.com/${1}/${1}-bundle.pem -o ${1}-bundle.pem
}
govRegions=(
	"us-gov-east-1"  # AWS GovCloud (US-East)
	"us-gov-west-1"  # AWS GovCloud (US-West)
)
for region in "${govRegions[@]}"; do
   downloadGov ${region}
   echo "export default \`$(cat ${region}-bundle.pem)\`" > ${region}.js
   updateExport ${region}
done

rm -f *-bundle.pem
